# --- Required ---
# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Numeric Telegram user ID of the admin (get it from @userinfobot)
# Only this user can interact with the bot. Everyone else is silently ignored.
ADMIN_USER_ID=123456789

# Channel where validated configs are published (bot MUST be admin here).
# Use @channelusername for public channels or a numeric -100... id for private ones.
PUBLISH_CHANNEL=@webdw

# --- Optional (defaults tuned for Hetzner CX22: 2 vCPU / 4 GB RAM) ---

# Max wait for the TCP connectivity probe per config (ms).
# Lower = faster scrape, but more false negatives on slow servers.
TCP_TIMEOUT_MS=2500

# How many TCP probes to run in parallel. CX22 handles ~300 comfortably.
# Raise to 500-800 on a bigger box; lower to 150 on a 1 vCPU VPS.
VALIDATION_CONCURRENCY=300

# Hard cap on how many fresh configs are validated per scrape cycle.
# Sources like the multi-sub aggregators can return 50k+ configs; processing
# all of them every cycle would lock the cycle for hours. We randomly sample
# this many and validate them concurrently.
MAX_CONFIGS_PER_CYCLE=1200

# Cron schedule for publishing one validated config (default: every minute)
PUBLISH_CRON=* * * * *

# Cron schedule for full scrape+validate cycle (default: every 10 minutes)
SCRAPE_CRON=*/10 * * * *

# SQLite database file path
DB_PATH=./data/bot.sqlite

# Winston log level (error | warn | info | debug)
LOG_LEVEL=info
