# ── Required ────────────────────────────────────────────────
# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Numeric Telegram user ID of the admin (get it from @userinfobot)
# Only this user can interact with the bot. Everyone else is silently ignored.
ADMIN_USER_ID=123456789

# Channel where validated configs are published (bot MUST be admin here).
# Use @channelusername for public channels or a numeric -100... id for private ones.
PUBLISH_CHANNEL=@yourchannel

# ── Optional — Scheduling ────────────────────────────────────
# Cron schedule for publishing one validated config (default: every minute)
PUBLISH_CRON=* * * * *

# Cron schedule for full scrape+validate cycle (default: every 10 minutes)
SCRAPE_CRON=*/10 * * * *

# ── Optional — Performance (auto-detected from hardware if left blank) ────────
# Max wait for the TCP connectivity probe per config (ms).
# Lower = faster scrape, but more false negatives on slow servers.
# TCP_TIMEOUT_MS=2500

# How many TCP probes to run in parallel.
# Auto-detected: 1vCPU/2GB→100  |  2vCPU/4GB→300  |  4vCPU/8GB→600  |  8+vCPU→1000
# VALIDATION_CONCURRENCY=300

# Hard cap on how many fresh configs are validated per scrape cycle.
# Auto-detected: 1vCPU/2GB→400  |  2vCPU/4GB→1200  |  4vCPU/8GB→2500  |  8+vCPU→5000
# MAX_CONFIGS_PER_CYCLE=1200

# ── Optional — Storage ───────────────────────────────────────
# SQLite database file path
DB_PATH=./data/bot.sqlite

# Local directory for generated subscription .txt files
SUBS_DIR=./subs

# Winston log level (error | warn | info | debug)
LOG_LEVEL=info

# ── Optional — GitHub Auto-Publisher ─────────────────────────
# Leave GITHUB_TOKEN blank to disable GitHub publishing entirely.
# The bot will still generate local subscription files under SUBS_DIR.

# Personal access token with "Contents: Read & Write" scope
GITHUB_TOKEN=

# Target repository (owner/repo), e.g. "myuser/v2ray-subs"
GITHUB_REPO=

# Branch to commit sub files to (default: main)
GITHUB_BRANCH=main

# Subdirectory inside the repo where sub files are placed (default: subs)
SUB_DIR=subs

# Minimum time between GitHub pushes in ms (default: 5 minutes = 300000)
# Prevents hammering the API on rapid-fire scrape cycles
GITHUB_PUSH_INTERVAL_MS=300000
